{
  "name": "vbi-pme",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:vite": "vite --port=3000",
    "dev:electron": "wait-on http://localhost:3000 && electron .",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "clean:build": "node -e \"const fs=require('fs'); for (const p of ['dist','dist-exe']) fs.rmSync(p,{recursive:true,force:true});\"",
    "lint": "tsc --noEmit",
    "electron:dev": "concurrently -k -s first -n VITE,ELECTRON \"npm run dev:vite\" \"npm run dev:electron\"",
    "rebuild:native": "electron-builder install-app-deps",
    "build:exe": "npm run clean:build && vite build && electron-builder --win"
  },
  "build": {
    "appId": "com.vbi.pme",
    "productName": "VBI PME",
    "directories": {
      "output": "dist-exe"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VBI PME",
      "artifactName": "VBI PME Setup.exe"
    }
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wait-on": "^9.0.10"
  }
}
